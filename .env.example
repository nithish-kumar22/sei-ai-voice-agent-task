# =============================================================================
# Qdrant / FAQ ingestion (run_wise_faq_pipeline.py + FastAPI retrieval)
# =============================================================================
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_COLLECTION_NAME=wise_where_is_my_money
# Sentence-transformers model that outputs 512 dimensions (required for collection)
EMBEDDING_MODEL=sentence-transformers/distiluse-base-multilingual-cased-v1

# Qdrant API key (optional, for Qdrant Cloud)
# QDRANT_API_KEY=

# =============================================================================
# LLM provider (OpenRouter for chat; get API key from https://openrouter.ai)
# =============================================================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# =============================================================================
# LiveKit (voice agent worker + frontend token)
# =============================================================================
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# =============================================================================
# FastAPI server
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173
# Base URL of the FastAPI app (for LiveKit agent worker to call /api/voice/turn)
API_BASE_URL=http://localhost:8000
# Timeout in seconds for worker -> FastAPI /api/voice/turn (default 60; increase if backend is slow)
# VOICE_TURN_TIMEOUT=60

# =============================================================================
# Optional: Telephony (Twilio SIP for PSTN inbound)
# =============================================================================
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SIP_DOMAIN=
# Outbound calls (trunk ID from LiveKit Cloud SIP / Outbound trunk)
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# =============================================================================
# Voice agent TTS (Piper – free, no API key; requires a local Piper server)
# =============================================================================
PIPER_TTS_BASE_URL=http://localhost:5000
